# Normalize line endings to LF in the repo and on checkout (consistent cross-OS).
* text=auto eol=lf

# Windows-only scripts keep CRLF
*.cmd  text eol=crlf
*.bat  text eol=crlf
*.ps1  text eol=crlf

# Binary assets — never normalize
*.ico  binary
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.webp binary
*.woff  binary
*.woff2 binary

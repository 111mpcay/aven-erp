# ============================================================
#  Aven ERP — environment variables (TEMPLATE)
#  Copy to .env.local and fill in real values. NEVER commit .env.local.
#  In Vercel, set these per-environment; mark the SERVER-ONLY ones "Sensitive".
# ============================================================

# ---- PUBLIC (exposed to the browser; safe ONLY with RLS enabled) ----
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
# Supabase dashboard -> Project Settings -> API Keys -> "Publishable key" (sb_publishable_...)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxx

# ---- SERVER-ONLY (never prefix with NEXT_PUBLIC_; "Sensitive" in Vercel) ----
# Bypasses RLS — admin/server context only, never sent to the browser.
# Dashboard -> Project Settings -> API Keys -> "Secret key" (sb_secret_...)
SUPABASE_SECRET_KEY=sb_secret_xxxxxxxxxxxxxxxx

# Runtime queries -> Supavisor TRANSACTION pooler, port 6543 (Drizzle uses { prepare: false }).
# Dashboard -> Connect -> ORMs/Drizzle (or "Transaction pooler"). Replace [YOUR-PASSWORD].
DATABASE_URL=postgresql://postgres.<ref>:[YOUR-DB-PASSWORD]@aws-1-<region>.pooler.supabase.com:6543/postgres

# Migrations + RLS-bypass admin client -> SESSION pooler, port 5432 (IPv4-safe).
# Dashboard -> Connect -> "Session pooler". Replace [YOUR-PASSWORD].
ADMIN_DATABASE_URL=postgresql://postgres.<ref>:[YOUR-DB-PASSWORD]@aws-1-<region>.pooler.supabase.com:5432/postgres

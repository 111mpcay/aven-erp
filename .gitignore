# ---- dependencies ----
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ---- Next.js ----
/.next/
/out/
/build
next-env.d.ts
*.tsbuildinfo

# ---- testing / coverage ----
/coverage
/.nyc_output

# ---- env & secrets (NEVER commit) ----
.env
.env.*
.env.local
# allow checked-in example templates
!.env.example
!.env.*.example

# ---- Supabase (local CLI artifacts) ----
supabase/.branches
supabase/.temp
supabase/.env

# ---- Vercel ----
.vercel

# ---- logs ----
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
*.log

# ---- editor / OS ----
.DS_Store
Thumbs.db
*.pem
.idea
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
